  seq_des$
  add_subject_to_experiment_and_assign(x_dat[i, , drop = FALSE])
}
seq_des$
  add_all_subject_responses(c(0, 1, 0, 1, 0, 1, 1, 0))
infer <- SeqDesignInferenceIncidUnivKKNewcombeRiskDiff$
  new(
  seq_des,
  verbose = FALSE
)
infer

