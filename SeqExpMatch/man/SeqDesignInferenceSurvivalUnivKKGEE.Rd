}
seq_des$add_all_subject_responses(rexp(20, rate = 0.5), rep(1, 20))

seq_des_inf = SeqDesignInferenceSurvivalUnivKKGEE$new(seq_des)
seq_des_inf$compute_treatment_estimate()
}
}
