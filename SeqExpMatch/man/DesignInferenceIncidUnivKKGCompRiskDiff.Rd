}
seq_des$
  add_all_subject_responses(c(0, 1, 0, 1, 0, 1, 1, 0))
infer <- DesignInferenceIncidUnivKKGCompRiskDiff$
  new(
  seq_des,
  verbose = FALSE
)
infer

