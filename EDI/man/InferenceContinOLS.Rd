\subsection{Method \code{new()}}{
Initialize an OLS inference object.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{InferenceContinOLS$new(
  des_obj,
  model_formula = NULL,
  verbose = FALSE,
  max_resample_attempts = 50L
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{des_obj}}{A completed \code{Design} object with a continuous response.}

\item{\code{model_formula}}{Optional formula for covariate adjustment. If \code{NULL} (default),
the formula from the design object is used and its pre-computed design matrix is
reused. If a formula is provided, a new design matrix is constructed from the
design's imputed covariates.}

\item{\code{verbose}}{Whether to print progress messages.}

\item{\code{max_resample_attempts}}{Maximum number of times a single bootstrap replicate
may be redrawn when the drawn sample fails validity screening. Default \code{50L}.}
}
\if{html}{\out{</div>}}
}
}
